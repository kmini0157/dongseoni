# 동선이 푸시 서버 환경변수 — 이 파일을 .env 로 복사해 채우세요 (.env 는 커밋 금지)
PORT=8787
VAPID_SUBJECT=mailto:you@example.com
# 아래 두 키는 `npm run gen-keys` (= npx web-push generate-vapid-keys) 로 생성
VAPID_PUBLIC=여기에_공개키_붙여넣기
VAPID_PRIVATE=여기에_비밀키_붙여넣기
# 선택: 구독/알람 저장 파일 경로 (기본 ./data.json)
# DATA_FILE=/data/dongseoni.json
# 선택: 한국관광공사 TourAPI 서비스키(인코딩키) — /tourapi 프록시용. 설정하면 클라이언트는 키 없이 추천 사용
# TOURAPI_KEY=여기에_data.go.kr_서비스키
